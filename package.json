{
  "name": "@lass-lang/core",
  "version": "0.0.1",
  "description": "Lass language transpiler core",
  "author": "Long-lazuli",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@lass-lang/axioms": "^0.0.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "lass",
    "css",
    "transpiler",
    "preprocessor",
    "js-in-css",
    "styling",
    "build-tool",
    "template-literals"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lass-lang/core.git"
  },
  "bugs": {
    "url": "https://github.com/lass-lang/core/issues"
  },
  "homepage": "https://github.com/lass-lang/core#readme"
}
